# Vite / frontend environment (copy to .env.local for local overrides)

# API base URL. Use /api in production (same Vercel deployment) or when using the Vite dev proxy.
# VITE_API_URL=/api

# Socket.io server URL (local dev only — real-time messaging needs a long-running Node server).
# VITE_SOCKET_URL=http://localhost:5001

# Terms page version label
# VITE_TERMS_VERSION=2026-06
