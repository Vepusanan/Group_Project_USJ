# Vite / frontend environment (copy to .env.local for local overrides)

# API base URL. Use /api for same-origin production (Railway or Vercel monolith).
# VITE_API_URL=/api

# Socket.io — only needed when API runs on a different host than the SPA.
# Same-origin Railway deploy: leave unset (client connects to current host).
# VITE_SOCKET_URL=http://localhost:5001

# Terms page version label
# VITE_TERMS_VERSION=2026-06
