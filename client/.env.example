# Vite / frontend environment (copy to .env.local for local overrides)

# API base URL — use /api on Vercel (same deployment)
VITE_API_URL=/api

# Supabase Realtime (required for instant messaging)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Terms page version label
# VITE_TERMS_VERSION=2026-06
