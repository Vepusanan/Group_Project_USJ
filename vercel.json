{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "npm ci --prefix client && npm ci --prefix server",
  "buildCommand": "VITE_API_URL=/api npm run build --prefix client",
  "outputDirectory": "client/dist",
  "framework": null,
  "env": {
    "VITE_API_URL": "/api"
  },
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "server/**"
    },
    "api/cron/cleanup.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "server/**"
    }
  },
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 2 * * *"
    }
  ]
}
