# Copy to .env and fill in values. Never commit .env.

# Database (Supabase pooler URL recommended)
DATABASE_URL=
DB_PASSWORD=

# Supabase storage
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Optional: dedicated service role key (preferred over anon for server uploads)
# SUPABASE_SERVICE_KEY=

# Server
PORT=5001
NODE_ENV=development
BASE_URL=http://localhost:5001
FRONTEND_URL=http://localhost:3000

# Auth
JWT_SECRET=
JWT_VERIFY_SECRET=

# Admin — comma-separated emails allowed to access /api/admin/*
ADMIN_EMAILS=

# Email — Brevo SMTP (recommended)
EMAIL_SMTP_HOST=smtp-relay.brevo.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_PASS=
# Verified sender in Brevo dashboard (display name / From address)
EMAIL_FROM=
# Optional: set true in dev to log links in terminal instead of sending mail
EMAIL_DEV_LOG_ONLY=false

# Email — Gmail fallback (omit EMAIL_SMTP_HOST to use this instead)
# EMAIL_SERVICE=gmail
# EMAIL_USER=
# EMAIL_PASS=

# Google Gemini (optional — AI features fall back when unset)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Security (optional)
# CONNECTION_NOTES_ENCRYPTION_KEY=
# ENABLE_MALWARE_SCAN=false
# GEMINI_TIMEOUT_MS=10000
# AI_RATE_LIMIT_PER_HOUR=30
# ALLOWED_STORAGE_HOSTS=your-project.supabase.co
# MAX_PITCH_DECK_BYTES=26214400
# PITCH_DECK_FETCH_TIMEOUT_MS=15000
# PITCH_DECK_SESSION_RATE_PER_MIN=120
# SLOW_REQUEST_MS=500
# CRON_TIMEZONE=Asia/Colombo
# TERMS_VERSION=2026-06
# DB_POOL_MAX=10
